# Health OS — environment configuration
# Copy this file to .env.local and fill in your credentials:
#   cp .env.example .env.local

GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Port for the local server (default 8787)
PORT=8787

# How often to auto-sync Garmin data in the background (minutes, default 180)
SYNC_INTERVAL_MIN=180

# AI coaching for food analysis and daily coaching — optional
# Leave blank to use the Health OS Cowork artifact (no key needed)
# Get your key from: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
